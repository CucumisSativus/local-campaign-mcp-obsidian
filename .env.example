# Required: Paths to your campaign data
LOCATIONS_PATH=/path/to/your/campaign/Locations
CHARACTERS_PATH=/path/to/your/campaign/Characters
SESSIONS_PATH=/path/to/your/campaign/sessions

# Required for HTTP mode: API key for authentication
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
API_KEY=your-secure-api-key-here

# Optional for HTTP mode: Server configuration
HOST=0.0.0.0
PORT=8000
